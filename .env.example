# ============================================================
# Kron CMS — ortam degiskenleri ornegi
# Kullanim:  cp .env.example .env   (uretim icin tum secret'lari degistirin)
# ============================================================

# --- Genel ---
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_USER=kron
POSTGRES_PASSWORD=kron_dev_pw
POSTGRES_DB=kron_cms
# API container'i icinden (docker network uzerinden 'postgres' host'u)
DATABASE_URL=postgresql://kron:kron_dev_pw@postgres:5432/kron_cms?schema=public

# --- Redis (cache + zamanlanmis yayin kuyrugu) ---
REDIS_URL=redis://redis:6379

# --- MinIO (S3 uyumlu obje depolama) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000        # container ici erisim
S3_PUBLIC_URL=http://localhost:9000  # tarayicidan erisilen medya URL'i
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=kron-media
S3_FORCE_PATH_STYLE=true

# --- API (NestJS) ---
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900       # saniye (15 dk)
JWT_REFRESH_TTL=604800   # saniye (7 gun)
# Rate limiting (pencere basina istek)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
# Ilk admin kullanicisi (seed)
ADMIN_EMAIL=admin@kron.local
ADMIN_PASSWORD=Admin123!
# Imzali preview link'leri icin
PREVIEW_SECRET=change-me-preview-secret

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000   # tarayicidan (public istemci)
API_INTERNAL_URL=http://api:4000            # SSR/ISR sunucu tarafindan (docker network ici)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NEXT_PUBLIC_LOCALES=tr,en
# API publish edince Next ISR cache'ini temizlemek icin paylasilan secret
REVALIDATE_SECRET=change-me-revalidate-secret

# --- Spam koruma (formlar) ---
# 'none' ise honeypot + rate-limit kullanilir; 'hcaptcha'/'turnstile' icin secret girin
CAPTCHA_PROVIDER=none
CAPTCHA_SECRET=
